@article{liang_high-pressure_2026,
	title = {High-pressure formation and characterization of a boron carbide polymorph featuring bent {C}–{B}–{C} chains},
	volume = {113},
	issn = {2469-9950, 2469-9969},
	url = {https://link.aps.org/doi/10.1103/v5kf-svcz},
	doi = {10.1103/v5kf-svcz},
	abstract = {Boron carbide is a material of choice for multiple industries, e.g., aerospace, as a lightweight structural ceramic due to its high hardness, high melting temperature, and low density. However, its mechanical properties have been observed to radically degrade under shockwave compression, presumably as a consequence of stress-induced phase transitions resulting in its partial amorphization. So far, the physical mechanism underpinning this behavior remains unclear. Here, we report a pressure-induced phase transition in boron carbide occurring between 78 and 90 GPa during static compression in diamond anvil cells, both at room temperature and after quenching from high temperatures. The crystal structure of the new phase was solved and refined via synchrotron single-crystal x-ray diffraction measurements and further investigated by Raman spectroscopy as well as density functional theory calculations. The discovered high-pressure polymorph, 𝑚𝐶⁢60−B13⁢C2, has strong resemblance with the known ambient conditions phase, ℎ𝑅⁢45−B13⁢C2, with the important distinction that the linear C–B–C chain linking B12 icosahedra in ℎ𝑅⁢45−B13⁢C2 is bent in 𝑚𝐶⁢60−B13⁢C2. Such bending of the C–B–C chain has been hypothesized as key to explain boron carbide's drop in strength, phase transitions, and amorphization. The observed reversibility of the phase transition, as well as the formation of covalent bonds between B12 icosahedra and the bent C–B–C chains, are assessed to decipher the C–B–C chain's bending importance on the amorphization and mechanical properties of boron carbide.},
	language = {en},
	number = {10},
	urldate = {2026-03-20},
	journal = {Phys. Rev. B},
	author = {Liang, Akun and Ranieri, Umbertoluca and Spender, James and Lamb, Charles and Bolton, Sarah and Massani, Bernhard and McWilliams, Ryan Stewart and Fedotenko, Timofey and Glazyrin, Konstantin and Giordano, Nico and Wright, Jonathan and Trybel, Florian and Laniel, Dominique},
	month = mar,
	year = {2026},
	pages = {104108},
	file = {PDF:C\:\\Users\\mysel\\Zotero\\storage\\MSBP7A5Q\\Liang et al. - 2026 - High-pressure formation and characterization of a boron carbide polymorph featuring bent C–B–C chain.pdf:application/pdf},
}


@article{ranieri_dynamical_2016,
	title = {Dynamical {Crossover} in {Hot} {Dense} {Water}: {The} {Hydrogen} {Bond} {Role}},
	volume = {120},
	issn = {1520-6106, 1520-5207},
	shorttitle = {Dynamical {Crossover} in {Hot} {Dense} {Water}},
	url = {https://pubs.acs.org/doi/10.1021/acs.jpcb.6b04142},
	doi = {10.1021/acs.jpcb.6b04142},
	abstract = {We investigate the terahertz dynamics of liquid H2O as a function of pressure along the 450 K isotherm, by coupled quasielastic neutron scattering and inelastic X-ray scattering experiments. The pressure dependence of the single-molecule dynamics is anomalous in terms of both microscopic translation and rotation. In particular, the Stokes–Einstein-Debye equations are shown to be violated in hot water compressed to the GPa regime. The dynamics of the hydrogen bond network is only weakly affected by the pressure variation. The time scale of the structural relaxation driving the collective dynamics increases by a mere factor of 2 along the investigated isotherm, and the structural relaxation strength turns out to be almost pressure independent. Our results point at the persistence of the hydrogen bond network in hot dense water up to ice VII crystallization, thus questioning the long-standing perception that hydrogen bonds are broken in liquid water under the effect of compression.},
	language = {en},
	number = {34},
	urldate = {2026-03-20},
	journal = {J. Phys. Chem. B},
	author = {Ranieri, Umbertoluca and Giura, Paola and Gorelli, Federico A. and Santoro, Mario and Klotz, Stefan and Gillet, Philippe and Paolasini, Luigi and Koza, Michael Marek and Bove, Livia E.},
	month = sep,
	year = {2016},
	pages = {9051--9059},
	file = {PDF:C\:\\Users\\mysel\\Zotero\\storage\\EEP42C2J\\Ranieri et al. - 2016 - Dynamical Crossover in Hot Dense Water The Hydrogen Bond Role.pdf:application/pdf},
}

@article{ranieri_fast_2017,
	title = {Fast methane diffusion at the interface of two clathrate structures},
	volume = {8},
	issn = {2041-1723},
	url = {https://www.nature.com/articles/s41467-017-01167-2},
	doi = {10.1038/s41467-017-01167-2},
	abstract = {Methane hydrates naturally form on Earth and in the interiors of some icy bodies of the Universe, and are also expected to play a paramount role in future energy and environmental technologies. Here we report experimental observation of an extremely fast methane diffusion at the interface of the two most common clathrate hydrate structures, namely clathrate structures I and II. Methane translational diffusion—measured by quasielastic neutron scattering at 0.8 GPa—is faster than that expected in pure supercritical methane at comparable pressure and temperature. This phenomenon could be an effect of strong confinement or of methane aggregation in the form of micro-nanobubbles at the interface of the two structures. Our results could have implications for understanding the replacement kinetics during sI–sII conversion in gas exchange experiments and for establishing the methane mobility in methane hydrates embedded in the cryosphere of large icy bodies in the Universe.},
	language = {en},
	number = {1},
	urldate = {2026-03-20},
	journal = {Nat Commun},
	author = {Ranieri, Umbertoluca and Koza, Michael Marek and Kuhs, Werner F. and Klotz, Stefan and Falenty, Andrzej and Gillet, Philippe and Bove, Livia E.},
	month = oct,
	year = {2017},
	pages = {1076},
	file = {PDF:C\:\\Users\\mysel\\Zotero\\storage\\B5KDA29I\\Ranieri et al. - 2017 - Fast methane diffusion at the interface of two clathrate structures.pdf:application/pdf},
}

@article{schaack_orientational_2018,
	title = {Orientational {Ordering}, {Locking}-in, and {Distortion} of {CH}$_{4}$ {Molecules} in {Methane} {Hydrate} {III} under {High} {Pressure}},
	volume = {122},
	issn = {1932-7447, 1932-7455},
	url = {https://pubs.acs.org/doi/10.1021/acs.jpcc.8b02783},
	doi = {10.1021/acs.jpcc.8b02783},
	abstract = {We investigate the effects of high pressure on the reorientational and vibrational dynamics of methane molecules embedded in methane hydrate III—the stable form of methane for pressures above 2 GPa at room temperature—by combining high-pressure Raman spectroscopy with ab initio simulations including nuclear quantum effects. We observe a clear evolution of the system from a gas-filled ice structure, where methane molecules occupy the channels of the ice skeleton and rotate almost freely, to a CH4:D2O compound where methane rotations are hindered, and methane and water dynamics are tightly coupled. The gradual orientational ordering of the guest molecules results in a complete locking-in at approximately 20 GPa. This happens along with a progressive distortion of the guest molecules. Finally, as pressure increases beyond 20 GPa, the system enters a strong mode coupling regime where methane guests and water hosts dynamics are intimately paired.},
	language = {en},
	number = {20},
	urldate = {2026-03-20},
	journal = {J. Phys. Chem. C},
	author = {Schaack, Sofiane and Ranieri, Umbertoluca and Depondt, Philippe and Gaal, Richard and Kuhs, Werner F. and Falenty, Andrzej and Gillet, Philippe and Finocchi, Fabio and Bove, Livia E.},
	month = may,
	year = {2018},
	pages = {11159--11166},
	file = {26. Liang JACS Au 2026:C\:\\Users\\mysel\\Zotero\\storage\\JTZK9RMV\\26. Liang JACS Au 2026.pdf:application/pdf;PDF:C\:\\Users\\mysel\\Zotero\\storage\\NS46Z3LF\\Schaack et al. - 2018 - Orientational Ordering, Locking-in, and Distortion of CH4 Molecules in Methane Hydrate II.pdf:application/pdf},
}

@article{ranieri_quantum_2019,
